# ---- Helpdesk bench: ONE container stack hosting TWO sites ----------------
#   support.testable.org      (separate database)
#   mindssupport.testable.org (separate database)
# Sites are resolved by hostname (DNS-based multitenancy), so they share
# compute but have fully isolated data.

# Official, prebuilt image maintained by Frappe (frappe version-15 + helpdesk +
# telephony, assets baked in). It's a PUBLIC GHCR package — no docker login, no
# build pipeline. The server just pulls it.
#   Pin a release tag (e.g. v1.26.2) for reproducibility; `stable` = latest main
#   build. Browse tags: https://github.com/frappe/helpdesk/pkgs/container/helpdesk
CUSTOM_IMAGE=ghcr.io/frappe/helpdesk
CUSTOM_TAG=v1.26.2
PULL_POLICY=always

# Shared MariaDB (the mariadb-shared override names its container this).
DB_HOST=mariadb-database
DB_PORT=3306
# MUST match gitops/mariadb.env DB_PASSWORD.
DB_PASSWORD=CHANGE_ME_strong_db_root_password

# Project / network name for this bench.
ROUTER=helpdesk

# Internal Traefik host rule -> route BOTH hostnames to this bench.
SITES_RULE=Host(`support.testable.org`) || Host(`mindssupport.testable.org`)

# IMPORTANT: leave this UNSET (default `$host`) so each hostname resolves to
# its OWN site. Do NOT pin it to a single site here — that would force both
# hostnames to serve the same site. (Apache preserves the Host header.)
# FRAPPE_SITE_NAME_HEADER=

# Apache terminates TLS; trust its forwarded scheme/IP so redirects + cookies
# are correct.
UPSTREAM_REAL_IP_ADDRESS=0.0.0.0

# Gunicorn sizing — tune to the box. Formula: (2 * CPU cores) + 1.
# This pool serves BOTH sites, so size for combined load.
GUNICORN_WORKERS=4
GUNICORN_THREADS=4
GUNICORN_TIMEOUT=120
