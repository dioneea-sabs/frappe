# ---- Helpdesk bench (one Frappe instance) --------------------------------
# Copy this file per additional instance, changing ROUTER + SITES_RULE +
# FRAPPE_SITE_NAME_HEADER + CUSTOM_IMAGE.

# The custom image built by build.sh. PULL_POLICY=never => use the locally
# built image instead of trying to pull from a registry.
CUSTOM_IMAGE=helpdesk
CUSTOM_TAG=v16
PULL_POLICY=never

# Shared MariaDB (the mariadb-shared override names its container this).
DB_HOST=mariadb-database
DB_PORT=3306
# MUST match gitops/mariadb.env DB_PASSWORD.
DB_PASSWORD=CHANGE_ME_strong_db_root_password

# Project / network name for THIS bench. Must be unique per instance.
ROUTER=helpdesk

# Traefik host rule -> which hostnames route to this bench.
# Use the real public hostname you will point DNS at.
SITES_RULE=Host(`helpdesk.example.com`)

# Force this bench's nginx to always serve this exact site, regardless of the
# Host header it receives. Set it to the site name you create (= the hostname).
FRAPPE_SITE_NAME_HEADER=helpdesk.example.com

# Apache terminates TLS; tell Frappe the original scheme so redirects/cookies
# are correct. (Apache sets X-Forwarded-Proto: https — see apache/helpdesk.conf.)
UPSTREAM_REAL_IP_ADDRESS=0.0.0.0

# Gunicorn sizing — tune to the box. Formula: (2 * CPU cores) + 1.
GUNICORN_WORKERS=2
GUNICORN_THREADS=4
GUNICORN_TIMEOUT=120
