# Internal Traefik router shared by ALL benches.
# It is the single internal entrypoint; Apache (the public TLS edge) proxies
# to it. It is bound to LOCALHOST ONLY so it is never reachable from outside.
#
# Bind to 127.0.0.1:8080 (host:8080 -> traefik:80). Do NOT use 0.0.0.0 here.
HTTP_PUBLISH_PORT=127.0.0.1:8080

# Traefik dashboard host (only reachable via localhost:8080 with this Host
# header). Cosmetic for this setup, but the override requires it to be set.
TRAEFIK_DOMAIN=traefik.localhost

# Basic-auth for the dashboard. Generate with:
#   htpasswd -nbB admin 'your-password'
# then DOUBLE every '$' (compose interpolation), e.g. $2y$05$... -> $$2y$$05$$...
HASHED_PASSWORD=CHANGE_ME_htpasswd_bcrypt_with_doubled_dollar_signs
