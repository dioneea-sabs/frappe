# Copy to .env and fill in:   cp .env.example .env
# dc.sh passes this to docker compose via --env-file.

# --- Image (official prebuilt, public GHCR package — nothing to build) --------
# Pin a release for reproducibility; `stable` = latest main build.
# Tags: https://github.com/frappe/helpdesk/pkgs/container/helpdesk
CUSTOM_IMAGE=ghcr.io/frappe/helpdesk
CUSTOM_TAG=v1.26.2
PULL_POLICY=always
RESTART_POLICY=unless-stopped
# Unused (CUSTOM_TAG wins) — defining it just silences a harmless compose warning.
ERPNEXT_VERSION=

# --- Database -----------------------------------------------------------------
# MariaDB root password (container DB; not your host MySQL). Also used by
# create-site.sh. The mariadb override wires DB_HOST=db automatically.
DB_PASSWORD=CHANGE_ME_strong_db_root_password

# --- Where the bench's nginx listens (HOST side) ------------------------------
# Localhost-only: Apache proxies to this. Do NOT use 0.0.0.0 (would expose the
# bench publicly, bypassing Apache/TLS).
HTTP_PUBLISH_PORT=127.0.0.1:8080

# --- Gunicorn sizing (serves BOTH sites) — formula: (2 * CPU cores) + 1 --------
GUNICORN_WORKERS=4
GUNICORN_THREADS=4
GUNICORN_TIMEOUT=120
